# ============================================================
#  Afleuressences — configuration Apache (OVH mutualisé)
#  À déposer à la racine web du nouveau site statique.
#  Objectif : préserver le SEO existant lors de la bascule WordPress -> site statique.
# ============================================================

RewriteEngine On

# ------------------------------------------------------------
# 1) HTTPS forcé + www -> non-www (cohérent avec l'existant)
# ------------------------------------------------------------
RewriteCond %{HTTPS} off
RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

RewriteCond %{HTTP_HOST} ^www\.(.+)$ [NC]
RewriteRule ^ https://%1%{REQUEST_URI} [L,R=301]

# ------------------------------------------------------------
# 2) Redirections 301 des ANCIENNES URLs WordPress -> nouvelles
#    (transfèrent ~90-99% du référencement accumulé)
#    Le ? après le / gère la présence ou non du slash final.
# ------------------------------------------------------------

# --- Pages FR ---
RedirectMatch 301 ^/artisan-fleuriste-l-union-toulouse/?$            /un-peu-de-moi
RedirectMatch 301 ^/fine-art-weddings/?$                              /prestations/fine-art-weddings
RedirectMatch 301 ^/fleurs-mariages-l-union-toulouse/?$              /prestations/mariages
RedirectMatch 301 ^/fleurs-evenements-l-union-toulouse/?$            /prestations/evenements-de-vie
RedirectMatch 301 ^/hommages-fleurs-l-union-toulouse/?$             /prestations/hommages
RedirectMatch 301 ^/cours-art-florale-l-union-toulouse/?$           /prestations/cours-art-floral
RedirectMatch 301 ^/planning-cours-art-floral/?$                    /prestations/cours-art-floral
RedirectMatch 301 ^/abonnements-floraux-l-union-toulouse/?$         /prestations/abonnements
RedirectMatch 301 ^/fleurissement-de-sepultures-par-abonnements/?$  /prestations/fleurissement-sepultures

# --- Pages EN (ancienne structure /en/<slug> -> nouvelle /en/... ) ---
RedirectMatch 301 ^/en/floral-toulouse/?$          /en/
RedirectMatch 301 ^/en/floral-artisan-toulouse/?$  /en/
RedirectMatch 301 ^/en/about-me/?$                 /en/about
RedirectMatch 301 ^/en/fine-art-floral/?$          /en/services/fine-art-weddings
RedirectMatch 301 ^/en/weddings/?$                 /en/services/weddings
RedirectMatch 301 ^/en/special-events/?$           /en/services/life-events
RedirectMatch 301 ^/en/funeral-arrangements/?$     /en/services/sympathy-flowers
RedirectMatch 301 ^/en/floral-art-classes/?$       /en/services/floral-workshops
RedirectMatch 301 ^/en/schedule/?$                 /en/services/floral-workshops
RedirectMatch 301 ^/en/subscriptions/?$            /en/services/subscriptions
RedirectMatch 301 ^/en/contact-info/?$             /en/contact

# --- Pages dont le slug ne change quasiment pas : on normalise le slash final ---
RedirectMatch 301 ^/contact/$                       /contact
RedirectMatch 301 ^/mentions-legales/$              /mentions-legales
RedirectMatch 301 ^/politique-de-confidentialite/$  /politique-de-confidentialite

# ------------------------------------------------------------
# 3) Ancien back-office WordPress : on coupe proprement
# ------------------------------------------------------------
RedirectMatch 301 ^/wp-admin/?.*$   /
RedirectMatch 301 ^/wp-login\.php$   /
<Files xmlrpc.php>
  Require all denied
</Files>

# ------------------------------------------------------------
# 4) URLs propres : /prestations/mariages -> /prestations/mariages.html
#    (sert le .html sans l'afficher dans la barre d'adresse)
# ------------------------------------------------------------
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME}\.html -f
RewriteRule ^(.+?)/?$ $1.html [L]

# Redirige /page.html -> /page (évite le contenu dupliqué)
RewriteCond %{THE_REQUEST} \s/+([^.\s]+)\.html[\s?] [NC]
RewriteRule ^ /%1 [L,R=301]

# ------------------------------------------------------------
# 5) En-têtes de sécurité (checklist standard)
# ------------------------------------------------------------
<IfModule mod_headers.c>
  Header always set X-Content-Type-Options "nosniff"
  Header always set X-Frame-Options "SAMEORIGIN"
  Header always set Referrer-Policy "strict-origin-when-cross-origin"
  Header always set Permissions-Policy "camera=(), microphone=(), geolocation=()"
  Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains"
</IfModule>

# ------------------------------------------------------------
# 6) Cache navigateur (performance)
# ------------------------------------------------------------
<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresByType image/jpeg   "access plus 1 year"
  ExpiresByType image/png    "access plus 1 year"
  ExpiresByType image/webp   "access plus 1 year"
  ExpiresByType text/css     "access plus 1 month"
  ExpiresByType text/javascript "access plus 1 month"
  ExpiresByType font/ttf     "access plus 1 year"
</IfModule>

# ------------------------------------------------------------
# 7) Page 404 personnalisée
# ------------------------------------------------------------
ErrorDocument 404 /404.html
